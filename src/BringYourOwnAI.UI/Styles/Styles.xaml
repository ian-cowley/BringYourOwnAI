<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VS Dark Theme colors (hardcoded to avoid XAML compile-time dependency on VS Shell 15.0) -->
    <!-- These match the VS Dark theme. At runtime the WPF DynamicResource merging in the VS
         shell will override these if the user uses a light theme via the tool window's theming. -->
    <SolidColorBrush x:Key="VsWindowBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="VsWindowText" Color="#D4D4D4" />
    <SolidColorBrush x:Key="VsHeaderBackground" Color="#2D2D30" />
    <SolidColorBrush x:Key="VsAccent" Color="#007ACC" />

    <!-- Base bubble style -->
    <Style x:Key="MessageBubbleBase" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="5,3" />
        <Setter Property="MaxWidth" Value="500" />
    </Style>

    <!-- User message bubble (right-aligned, blue) -->
    <Style x:Key="UserBubble" TargetType="Border" BasedOn="{StaticResource MessageBubbleBase}">
        <Setter Property="Background" Value="#0E639C" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <!-- Assistant message bubble (left-aligned, dark grey) -->
    <Style x:Key="AssistantBubble" TargetType="Border" BasedOn="{StaticResource MessageBubbleBase}">
        <Setter Property="Background" Value="#2D2D30" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- Sidebar list item style -->
    <Style x:Key="ConversationListItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="#D4D4D4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#094771" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3F3F46" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Flat send button style -->
    <Style x:Key="SendButton" TargetType="Button">
        <Setter Property="Background" Value="#007ACC" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1177BB" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#005A9E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
